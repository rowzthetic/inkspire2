.hn-badge {
  font-size: 10px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 10px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  flex-shrink: 0;
}

.hn-badge-today {
  background: rgba(29, 158, 117, 0.18);
  color: #1D9E75;
}

.hn-badge-sent {
  background: rgba(255,255,255,0.05);
  color: #555;
}

.hn-badge-upcoming {
  background: rgba(255,255,255,0.04);
  color: #444;
}

/* ── Textarea ── */
.hn-textarea {
  width: 100%;
  background: #0e0e0e;
  border: 1px solid #1e1e1e;
  border-radius: 0 0 8px 8px;
  color: #ccc;
  font-size: 13px;
  padding: 10px 14px;
  resize: vertical;
  box-sizing: border-box;
  font-family: inherit;
  outline: none;
  line-height: 1.5;
  display: block;
}

.hn-textarea:focus {
  border-color: #3f3f46;
}

/* ── Delete button ── */
.hn-delete-btn {
  background: transparent;
  border: none;
  color: #3a3a3a;
  cursor: pointer;
  padding: 3px 6px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  transition: color 0.15s;
  flex-shrink: 0;
}

.hn-delete-btn:hover {
  color: #ef4444;
}

/* ── Add note box ── */
.hn-add-box {
  margin-top: 12px;
  background: #141414;
  border: 1px dashed #2a2a2a;
  border-radius: 8px;
  padding: 14px;
}

.hn-add-trigger {
  width: 100%;
  margin-top: 12px;
  padding: 10px;
  background: transparent;
  border: 1px dashed #2a2a2a;
  border-radius: 8px;
  color: #555;
  font-size: 13px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: border-color 0.15s, color 0.15s;
}

.hn-add-trigger:hover {
  border-color: #444;
  color: #888;
}

/* ── Inputs inside add box ── */
.hn-input {
  background: #0e0e0e;
  border: 1px solid #2a2a2a;
  border-radius: 6px;
  color: #ddd;
  font-size: 13px;
  padding: 8px 10px;
  outline: none;
  font-family: inherit;
}

.hn-input:focus {
  border-color: #3f3f46;
}

.hn-cancel-btn {
  padding: 8px 14px;
  background: transparent;
  border: 1px solid #2a2a2a;
  border-radius: 6px;
  color: #666;
  font-size: 13px;
  cursor: pointer;
  transition: border-color 0.15s;
}

.hn-cancel-btn:hover {
  border-color: #444;
}
