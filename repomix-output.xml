    color: #a1a1aa; 
    display: flex; 
    flex-direction: column; 
    gap: 2px;
}

.closed-badge { font-weight: bold; color: #71717a; }

/* PORTFOLIO GRID */
.portfolio-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); 
    gap: 20px; 
}

.gallery-item { 
    height: 250px; 
    border-radius: 12px; 
    overflow: hidden; 
    border: 1px solid #333; 
    background-color: #111;
}

.gallery-item img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    transition: transform 0.3s; 
}

.gallery-item:hover img { transform: scale(1.05); }


/* ============================================
   MODAL STYLES - Streamlined Modern Design
   ============================================ */

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  backdrop-filter: blur(8px);
  animation: fadeIn 0.3s ease-out;
  padding: 20px;
}

/* Modal Content Container */
.modal-content {
  background: linear-gradient(145deg, #18181b 0%, #1f1f23 100%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20px;
  width: 100%;
  max-width: 480px;
  max-height: 85vh;
  overflow-y: auto;
  box-shadow: 
    0 25px 50px -12px rgba(0, 0, 0, 0.6),
    0 0 0 1px rgba(255, 255, 255, 0.05);
  animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  scrollbar-width: thin;
  scrollbar-color: #3f3f46 transparent;
}

.modal-content::-webkit-scrollbar {
  width: 6px;
}

.modal-content::-webkit-scrollbar-track {
  background: transparent;
}

.modal-content::-webkit-scrollbar-thumb {
  background-color: #3f3f46;
  border-radius: 3px;
}

/* Modal Header */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24px 24px 20px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  background: linear-gradient(180deg, rgba(39, 39, 42, 0.5) 0%, transparent 100%);
  position: sticky;
  top: 0;
  z-index: 10;
}

.modal-header-content {
  display: flex;
  align-items: center;
  gap: 16px;
}

.modal-day-badge {
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  color: white;
  font-size: 0.875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 8px 14px;
  border-radius: 10px;
  box-shadow: 0 4px 14px rgba(220, 38, 38, 0.35);
}

.modal-date-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.modal-date-info h3 {
  margin: 0;
  color: white;
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.2;
}

.modal-subtitle {
  color: #a1a1aa;
  font-size: 0.875rem;
}

/* Close Button */
.close-btn {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #a1a1aa;
  cursor: pointer;
  padding: 8px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.close-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  transform: rotate(90deg);
}

/* Modal Body */
.modal-body {
  padding: 24px;
}

/* Loading State */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  gap: 16px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid rgba(220, 38, 38, 0.2);
  border-top-color: #dc2626;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-state p {
  color: #a1a1aa;
  font-size: 0.95rem;
  margin: 0;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  text-align: center;
  gap: 16px;
}

.empty-icon {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #52525b;
  margin-bottom: 8px;
}

.empty-state h4 {
  color: white;
  font-size: 1.125rem;
  font-weight: 600;
  margin: 0;
}

.empty-state p {
  color: #71717a;
  font-size: 0.9rem;
  margin: 0;
  max-width: 280px;
  line-height: 1.5;
}

.empty-action-btn {
  margin-top: 8px;
  padding: 12px 24px;
  background: rgba(220, 38, 38, 0.1);
  border: 1px solid rgba(220, 38, 38, 0.3);
  color: #f87171;
  font-size: 0.9rem;
  font-weight: 500;
  border-radius: 10px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.empty-action-btn:hover {
  background: rgba(220, 38, 38, 0.2);
  border-color: rgba(220, 38, 38, 0.5);
  transform: translateY(-1px);
}

/* Slots Legend */
.slots-legend {
  display: flex;
  justify-content: center;
  gap: 24px;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.85rem;
  color: #a1a1aa;
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.legend-dot.available {
  background: #10b981;
  box-shadow: 0 0 8px rgba(16, 185, 129, 0.4);
}

.legend-dot.occupied {
  background: #52525b;
}

/* Time Slots Grid */
.slots-grid-popup {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: 12px;
}

/* Individual Slot Button */
.slot-popup-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16px 12px;
  border-radius: 12px;
  border: 1px solid;
  background: transparent;
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.slot-popup-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0;
  transition: opacity 0.3s ease;
}

/* Available Slot */
.slot-popup-btn.available {
  border-color: rgba(16, 185, 129, 0.3);
  background: rgba(16, 185, 129, 0.05);
}

.slot-popup-btn.available::before {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
}

.slot-popup-btn.available:hover {
  border-color: #10b981;
  background: rgba(16, 185, 129, 0.15);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(16, 185, 129, 0.2);
}

.slot-popup-btn.available:hover::before {
  opacity: 1;
}

.slot-popup-btn.available .slot-time {
  color: #34d399;
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 4px;
}

.slot-popup-btn.available .slot-action {
  color: #10b981;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.slot-popup-btn.available:hover .slot-time,
.slot-popup-btn.available:hover .slot-action {
  color: white;
}

/* Occupied Slot */
.slot-popup-btn.occupied {
  border-color: rgba(82, 82, 91, 0.3);
  background: rgba(39, 39, 42, 0.3);
  cursor: not-allowed;
  opacity: 0.7;
}

.slot-popup-btn.occupied .slot-time {
  color: #71717a;
  font-size: 1rem;
  font-weight: 500;
  margin-bottom: 4px;
  text-decoration: line-through;
}

.slot-popup-btn.occupied .slot-status {
  color: #52525b;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Modal Footer Text */
.modal-footer-text {
  text-align: center;
  color: #71717a;
  font-size: 0.85rem;
  margin: 20px 0 0;
  padding-top: 16px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

/* Animations */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes modalSlideUp {
  from { 
    transform: translateY(30px) scale(0.96); 
    opacity: 0; 
  }
  to { 
    transform: translateY(0) scale(1); 
    opacity: 1; 
  }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Responsive Design */
@media (max-width: 480px) {
  .modal-overlay {
    padding: 16px;
    align-items: flex-end;
  }
  
  .modal-content {
    max-height: 90vh;
    border-radius: 20px 20px 16px 16px;
    animation: modalSlideUpMobile 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .modal-header {
    padding: 20px 20px 16px;
  }
  
  .modal-header-content {
    gap: 12px;
  }
  
  .modal-day-badge {
    padding: 6px 10px;
    font-size: 0.75rem;
  }
  
  .modal-date-info h3 {
    font-size: 1.1rem;
  }
  
  .modal-subtitle {
    font-size: 0.8rem;
  }
  
  .modal-body {
    padding: 20px;
  }
  
  .slots-grid-popup {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  
  .slot-popup-btn {
    padding: 14px 10px;
  }
  
  .slot-popup-btn .slot-time {
    font-size: 0.95rem;
  }
  
  .slots-legend {
    gap: 16px;
  }
  
  .legend-item {
    font-size: 0.8rem;
  }
}

@keyframes modalSlideUpMobile {
  from { 
    transform: translateY(100%); 
    opacity: 0; 
  }
  to { 
    transform: translateY(0); 
    opacity: 1; 
  }
}

.placeholder-avatar {
