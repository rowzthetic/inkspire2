<file path="frontend/src/components/Dashboard/ArtistAppointments.css">
.appointments-wrapper {
    color: white;
    padding: 20px;
    max-width: 1400px;
    margin: 0 auto;
}

/* Statistics Section */
.statistics-section {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border: 1px solid #333;
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 24px;
}

.stats-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.stats-header h3 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.1rem;
    color: #fff;
}

.toggle-stats-btn {
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: white;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
}

.toggle-stats-btn:hover {
    background: rgba(255, 255, 255, 0.15);
}

.toggle-stats-btn svg.rotated {
    transform: rotate(180deg);
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
}

.stat-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-left: 4px solid;
    border-radius: 12px;
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    transition: all 0.2s ease;
}

.stat-card:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
}

.stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.stat-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.stat-label {
    font-size: 0.8rem;
    color: #a1a1aa;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stat-value {
    font-size: 1.75rem;
    font-weight: bold;
}

.stat-subtext {
    font-size: 0.75rem;
    color: #71717a;
}

/* Filter Section */
.filter-section {
    margin-bottom: 20px;
}

.filter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
}

.filter-header h2 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.25rem;
}

.filter-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #27272a;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid #444;
}

.filter-select {
    background: transparent;
    border: none;
    color: white;
    font-size: 0.95rem;
    cursor: pointer;
    outline: none;
    padding: 4px;
}

.filter-select option {
    background: #27272a;
    color: white;
}

/* Appointments List */
.appointments-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.appt-card {
    background-color: #18181b;
    border: 1px solid #333;
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.2s ease;
}

.appt-card:hover {
    border-color: #444;
}

.appt-card.pending {
    border-left: 4px solid #f59e0b;
}

.appt-card.confirmed {
    border-left: 4px solid #10b981;
}

.appt-card.cancelled {
    border-left: 4px solid #ef4444;
}

.appt-card.completed {
    border-left: 4px solid #3b82f6;
}

.appt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #333;
    padding-bottom: 12px;
    margin-bottom: 4px;
}

.appt-meta {
    display: flex;
    align-items: center;
    gap: 12px;
}

.status-badge {
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.status-badge.pending { background: #f59e0b; color: black; }
.status-badge.confirmed { background: #10b981; color: white; }
.status-badge.cancelled { background: #ef4444; color: white; }
.status-badge.completed { background: #3b82f6; color: white; }
.status-badge.reschedule { background: #8b5cf6; color: white; }

.upcoming-badge {
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.appt-date {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #a1a1aa;
    font-size: 0.9rem;
}

.appt-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}

@media (max-width: 768px) {
    .appt-body {
        grid-template-columns: 1fr;
    }
    
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

.client-info h3 {
    margin: 0 0 12px 0;
    font-size: 1.25rem;
    color: white;
}

.client-name, .time-slot, .duration {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #a1a1aa;
    margin: 6px 0;
    font-size: 0.95rem;
}

.appt-details p {
    margin: 6px 0;
    color: #d1d1d6;
    line-height: 1.5;
}

.appt-details strong {
    color: #fff;
}

.appt-details .description {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid #333;
}

.price-display {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    padding: 10px 14px;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    border-radius: 8px;
