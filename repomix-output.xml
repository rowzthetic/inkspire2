  justify-content: center;
}

.logout-btn:hover { border-color: var(--accent-red); color: var(--accent-red); }

/* --- MAIN CONTENT --- */
.dashboard-content {
  flex: 1;
  padding: 40px;
  overflow-y: auto;
}

.content-wrapper { max-width: 1100px; margin: 0 auto; }

.header-section {
