body {
  font-family: "Poppins", sans-serif;
  background-color: #111;
  color: #f5f5f5;
  line-height: 1.6;
}

/* Navbar */
.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.2rem 3rem;
  background: rgba(0, 0, 0, 0.8);
  position: sticky;
  top: 0;
  z-index: 1000;
}

.logo {
  font-size: 1.8rem;
  font-weight: bold;
  letter-spacing: 2px;
  color: #e63946;
}

.nav-links {
  list-style: none;
  display: flex;
  gap: 1.5rem;
}

.nav-links a {
  text-decoration: none;
  color: #f5f5f5;
  font-weight: 500;
  transition: color 0.3s ease;
}

.nav-links a:hover {
  color: #e63946;
}

/* Hero Section */
.hero {
  background: url('https://images.unsplash.com/photo-1504066294960-d53dfd1d5f3b?auto=format&fit=crop&w=1350&q=80') center/cover no-repeat;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.hero-content {
  background: rgba(0, 0, 0, 0.6);
  padding: 2rem;
  border-radius: 12px;
}

.hero h1 {
  font-size: 3rem;
  margin-bottom: 1rem;
  color: #fff;
}

.hero p {
  font-size: 1.2rem;
  margin-bottom: 2rem;
  color: #ddd;
}

.btn {
  background-color: #e63946;
  color: #fff;
  padding: 0.8rem 1.5rem;
  border: none;
  border-radius: 25px;
  cursor: pointer;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.3s ease;
}

.btn:hover {
  background-color: #c71c2c;
}

/* About Section */
.about {
  padding: 4rem 2rem;
  text-align: center;
  background-color: #181818;
}

.about h2 {
  font-size: 2rem;
  margin-bottom: 1.5rem;
  color: #e63946;
}

/* Gallery Section */
.gallery {
  padding: 4rem 2rem;
  text-align: center;
}

.gallery h2 {
  font-size: 2rem;
  margin-bottom: 2rem;
  color: #e63946;
}

.gallery .grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
}

.gallery img {
  width: 100%;
  border-radius: 10px;
  transition: transform 0.3s ease;
}

.gallery img:hover {
  transform: scale(1.05);
}

/* Artists Section */
.artists {
  padding: 4rem 2rem;
  text-align: center;
  background-color: #181818;
}

.artists h2 {
  color: #e63946;
  margin-bottom: 2rem;
}

.artist-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 2rem;
}

.card {
  background-color: #222;
  padding: 1.5rem;
  border-radius: 10px;
  transition: transform 0.3s ease;
}

.card:hover {
  transform: translateY(-5px);
}

.card img {
  border-radius: 50%;
  width: 120px;
  height: 120px;
  object-fit: cover;
  margin-bottom: 1rem;
}

/* Contact Section */
.contact {
  padding: 4rem 2rem;
  text-align: center;
}

.contact h2 {
  color: #e63946;
  margin-bottom: 2rem;
}

.contact-form {
  max-width: 500px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.contact-form input,
.contact-form textarea {
  padding: 0.8rem;
  border: none;
  border-radius: 8px;
  background: #222;
  color: #fff;
}

.contact-form button {
  align-self: center;
}

/* Footer */
footer {
  background: #000;
  padding: 1.5rem;
  text-align: center;
  font-size: 0.9rem;
  color: #bbb;
}

/* Shop Section */
/* --- SHOP SECTION UPDATES --- */

.shop {
  padding: 6rem 2rem 4rem 2rem; /* Increased top padding so it doesn't touch Navbar */
  text-align: center;
  background-color: #181818;
}

.shop h2 {
  color: #e63946;
  font-size: 2rem;
  margin-bottom: 1rem;
}

.shop-intro {
  color: #ccc;
  font-size: 1rem;
  max-width: 700px;
  margin: 0 auto 3rem auto;
}

.shop-grid {
  display: grid;
  /* This ensures cards stay at least 250px wide but stretch to fill space */
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
  gap: 2.5rem;
  justify-content: center;
  max-width: 1200px;
  margin: 0 auto; /* Centers the whole grid on the page */
}

.product {
  background-color: #222;
  border-radius: 12px;
  padding: 1.5rem;
  transition: transform 0.3s ease;
  
  /* These lines force the card to align contents vertically */
  display: flex;
  flex-direction: column;
  height: 100%; 
  justify-content: space-between; 
}

.product:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 20px rgba(0,0,0,0.3);
}

.product img {
  width: 100%;
  height: 250px; /* Forces all images to be the exact same height */
  object-fit: cover; /* Crops the image so it doesn't look squashed */
  border-radius: 10px;
  margin-bottom: 1rem;
}

.product h3 {
  color: #fff;
  margin-bottom: 0.5rem;
  font-size: 1.25rem;
}

.product p {
  color: #bbb;
  font-size: 0.95rem;
  margin-bottom: 1rem;
  flex-grow: 1; /* Pushes the button to the bottom */
}

.price {
  display: block;
  font-weight: bold;
  color: #e63946;
  font-size: 1.3rem;
  margin-bottom: 1rem;
}

.product .btn {
  width: 100%; /* Makes button fill the card width */
  padding: 0.8rem;
  font-size: 1rem;
}

/* Explore Section */
.explore {
  padding: 4rem 2rem;
  text-align: center;
  background-color: #111;
}

.explore h2 {
  color: #e63946;
  font-size: 2rem;
  margin-bottom: 1rem;
}

.explore-intro {
  color: #ccc;
  font-size: 1rem;
  max-width: 700px;
  margin: 0 auto 3rem auto;
}

.explore-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
}

.explore-card {
  background-color: #1e1e1e;
  border-radius: 12px;
  padding: 1.5rem;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.explore-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 0 10px rgba(230, 57, 70, 0.4);
}

.explore-card img {
  width: 100%;
  height: 160px;
  object-fit: cover;
  border-radius: 10px;
  margin-bottom: 1rem;
}

.explore-card h3 {
  color: #fff;
  margin-bottom: 0.5rem;
}

.explore-card p {
  color: #bbb;
  font-size: 0.9rem;
  margin-bottom: 1rem;
}

.explore-card .btn {
  padding: 0.6rem 1.2rem;
  font-size: 0.85rem;
}
/* --- PRICE ESTIMATOR PAGE --- */
.price-estimator {
  text-align: center;
  padding: 80px 20px;
  background-color: #111;
  color: #fff;
}

.price-estimator h2 {
  font-size: 2.5rem;
  margin-bottom: 10px;
  color: #ff4d4d;
}

.price-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
  max-width: 400px;
  margin: 30px auto;
  background: #1b1b1b;
  padding: 30px;
  border-radius: 12px;
  box-shadow: 0 0 10px rgba(255, 77, 77, 0.2);
}

.price-form label {
  font-weight: bold;
  text-align: left;
  color: #ccc;
}

.price-form select {
  padding: 10px;
  border-radius: 6px;
  border: none;
  background: #333;
  color: #fff;
}

.price-form .btn {
  background-color: #ff4d4d;
  border: none;
  padding: 12px;
  border-radius: 6px;
  color: white;
  cursor: pointer;
  font-weight: bold;
  transition: 0.3s;
}

.price-form .btn:hover {
  background-color: #e13c3c;
}

.price-result {
  margin-top: 20px;
  font-size: 1.3rem;
  font-weight: bold;
  color: #ff8080;
}

